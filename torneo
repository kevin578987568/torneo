                    SUM(CASE WHEN m.id_equipo_1 = e.id THEN m.puntos_equipo_2 WHEN m.id_equipo_2 = e.id THEN m.puntos_equipo_1 ELSE 0 END) as puntos_en_contra,
                    COALESCE(e.puntos_extra, 0) as puntos_extra,
                    e.estatus
                FROM equipos e
                LEFT JOIN matches m ON (e.id = m.id_equipo_1 OR e.id = m.id_equipo_2)
                GROUP BY e.id, e.nombre, e.logo, e.puntos_extra, e.estatus
                ORDER BY (COUNT(DISTINCT CASE WHEN m.id_ganador = e.id AND m.estatus_resultado != 'Empate' THEN m.id END) * 3 + COUNT(DISTINCT CASE WHEN m.estatus_resultado = 'Empate' AND (m.id_equipo_1 = e.id OR m.id_equipo_2 = e.id) THEN m.id END) + COALESCE(e.puntos_extra, 0)) DESC
            ");
            
            if ($tabla && mysqli_num_rows($tabla) > 0) {
                echo '<table><thead><tr><th>#</th><th>Equipo</th><th>PJ</th><th>V</th><th>E</th><th>D</th><th>GF</th><th>GC</th><th>Dif</th><th>Pts Extra</th><th>Total</th><th>Estado</th></tr></thead><tbody>';
                
                $pos = 1;
                while ($fila = mysqli_fetch_assoc($tabla)) {
                    $pj = intval($fila['victorias']) + intval($fila['empates']) + intval($fila['derrotas']);
                    $gf = intval($fila['puntos_a_favor']);
                    $gc = intval($fila['puntos_en_contra']);
                    $dif = $gf - $gc;
                    $pts_extra = intval($fila['puntos_extra']);
                    $total = (intval($fila['victorias']) * 3) + intval($fila['empates']) + $pts_extra;
                    $color_estado = ($fila['estatus'] == 'Baneado') ? '#ef4444' : '#10b981';
                    
                    echo '<tr>';
                    echo '<td style="font-weight:bold;color:#facc15">' . $pos . '</td>';
                    echo '<td>' . htmlspecialchars($fila['nombre']) . '</td>';
                    echo '<td>' . $pj . '</td>';
                    echo '<td style="color:#10b981;font-weight:bold">' . intval($fila['victorias']) . '</td>';
