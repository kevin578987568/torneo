<script>
function copiarAlPortapapeles(texto) {
    if (!texto) {
        texto = document.querySelector('.payment-ref-code').textContent;
    }
    navigator.clipboard.writeText(texto).then(() => {
        alert('✅ Referencia copiada al portapapeles');
    }).catch(err => {
        alert('❌ Error al copiar');
    });
}
