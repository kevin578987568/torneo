// ========== HELPERS ==========
function safe_query($conn, $sql) {
    $res = mysqli_query($conn, $sql);
    if ($res === false) {
        die("Error MySQL: " . mysqli_error($conn) . "<br><br>Consulta:<br>" . $sql);
    }
    return $res;
}

function safe_row($conn, $sql) {
    $res = safe_query($conn, $sql);
    if ($res === false) return null;
    $row = mysqli_fetch_assoc($res);
    return $row ?: null;
}

function safe_scalar($conn, $sql, $col = null) {
    $row = safe_row($conn, $sql);
    if ($row === null) return null;
    return $col === null ? array_values($row)[0] : ($row[$col] ?? null);
}

