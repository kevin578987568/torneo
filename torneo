                    echo '<td>' . $gc . '</td>';
                    echo '<td style="color:' . ($dif >= 0 ? '#10b981' : '#ef4444') . ';font-weight:bold">' . ($dif >= 0 ? '+' : '') . $dif . '</td>';
                    echo '<td>' . $pts_extra . '</td>';
                    echo '<td style="color:#facc15;font-weight:bold;font-size:1.1em">' . $total . '</td>';
                    echo '<td><span style="background:' . $color_estado . ';color:#fff;padding:4px 8px;border-radius:4px;font-size:0.85em;display:inline-block">' . htmlspecialchars($fila['estatus']) . '</span></td>';
